# ─────────────────────────────────────────────────────────────
# Backend environment variables
# Copy this file to `.env` inside the /server folder and fill in
# your Supabase project credentials.
# ─────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5000

# CORS — the origin of your Angular dev server (ng serve).
CLIENT_URL=http://localhost:4200

# Supabase ─ found in: Project Settings → API
# Project URL, e.g. https://xxxxxxxxxxxx.supabase.co
SUPABASE_URL=

# Service role key (server-side ONLY — never expose to the browser).
# Used so the API can bypass Row Level Security for trusted operations.
SUPABASE_SERVICE_ROLE_KEY=

# Rate limiting (requests per window, per IP)
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX=300
